# Model configuration.
LLM_PROVIDER=gemini

# Gemini model configuration.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_OUTPUT_TOKENS=800

# Optional OpenAI fallback configuration. Set LLM_PROVIDER=openai to use it.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=400
REQUEST_TIMEOUT_SECONDS=45

# Authentication and user storage.
# Set SECRET_KEY to a stable, long random value in production.
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///data/users.db

# Local frontend -> backend connection.
CLOUDSEC_API_URL=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000

# Backend server settings.
APP_NAME=CloudSec RAG Agent
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# RAG storage.
DATA_DIR=data
VECTORSTORE_DIR=vectorstore

# Optional local semantic embeddings. The model must already exist locally;
# the app will not download it at runtime.
ENABLE_SENTENCE_TRANSFORMER=false
SENTENCE_TRANSFORMER_MODEL_PATH=

# Request limits.
MAX_QUERY_CHARS=4000
MAX_ATTACHMENT_CHARS=12000
MAX_ATTACHMENT_COUNT=5
